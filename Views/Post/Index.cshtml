@model Bulletingboard.ViewModels.Post.PostListViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Bulletin Board";

    var publicPosts = Model.Data.Where(p => !p.IsPrivate);
    var privatePosts = Model.Data.Where(p => p.IsPrivate);
    int.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out int userId);
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">Bulletin Board</h2>
            <small class="text-muted">
                Share and manage posts
            </small>
        </div>

        <a class="btn btn-primary"
           asp-controller="Post"
           asp-action="Create">
             Create Post
        </a>
    </div>

    <div class="row">

        <!-- Public Posts -->
        <div class="col-lg-9">

            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0">
                        🌍 Public Posts
                    </h5>
                </div>

                <div class="card-body">

                    @if (!publicPosts.Any())
                    {
                        <div class="text-center py-4 text-muted">
                            <h5>No Public Posts</h5>
                            <p class="mb-0">
                                Create a public post to get started.
                            </p>
                        </div>
                    }

                    @foreach (var post in publicPosts)
                    {
                        <div class="card mb-4">

                            <div class="card-header bg-white">
                                <div class="d-flex justify-content-between align-items-center">

                                    <div>
                                        <strong>@post.UserName</strong>

                                        <span class="badge bg-success ms-2">
                                            Public
                                        </span>
                                    </div>

                                    <small class="text-muted">
                                        @post.CreatedAt
                                    </small>

                                </div>
                            </div>

                            <div class="card-body">

                                <p class="mb-0">
                                    @post.Description
                                </p>

                            </div>

                            <div class="card-footer bg-white">

                                <div class="d-flex gap-2 flex-wrap">

                                    <a class="btn btn-sm btn-outline-secondary"
                                       asp-action="Details"
                                       asp-route-id="@post.Id">
                                        Detail
                                    </a>

                                    @if (userId == post.UserId)
                                    {
                                        <a class="btn btn-sm btn-outline-warning"
                                           asp-action="Edit"
                                           asp-route-id="@post.Id">
                                            Edit
                                        </a>

                                        <form class="d-inline"
                                              asp-action="Delete"
                                              asp-route-id="@post.Id"
                                              method="post"
                                              onsubmit="return confirm('Delete this post?');">

                                            @Html.AntiForgeryToken()

                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger">
                                                Delete
                                            </button>

                                        </form>
                                    }

                                    @if (userId > 0)
                                    {
                                        <a class="btn btn-sm btn-outline-primary"
                                           data-bs-toggle="collapse"
                                           href="#commentForm-@post.Id">
                                            Add Comment
                                        </a>
                                    }

                                </div>

                            </div>

                            @if (userId > 0)
                            {
                                <div class="collapse border-top p-3"
                                     id="commentForm-@post.Id">

                                    <form asp-controller="Comment"
                                          asp-action="Create"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden"
                                               name="PostId"
                                               value="@post.Id" />

                                        <textarea class="form-control mb-2"
                                                  name="Content"
                                                  required
                                                  rows="3"
                                                  placeholder="Write a comment..."></textarea>

                                        <button type="submit"
                                                class="btn btn-primary btn-sm">
                                            Submit Comment
                                        </button>

                                    </form>

                                </div>
                            }

                            <div class="border-top p-3 bg-light">

                                <h6 class="mb-3">
                                    Comments (@(post.Comments?.Count ?? 0))
                                </h6>

                                @if (post.Comments?.Any() == true)
                                {
                                    <div class="border-top p-2">

                                        <small class="text-muted d-block mb-2">
                                            Comments (@post.Comments.Count)
                                        </small>

                                        @foreach (var comment in post.Comments)
                                        {
                                            <div class="mb-2">

                                                <div class="d-flex justify-content-between">

                                                    <strong class="small">
                                                        @comment.UserName
                                                    </strong>

                                                    <small class="text-muted">
                                                        @comment.CreatedAt
                                                    </small>

                                                </div>

                                                <div class="small">
                                                    @comment.Content
                                                </div>

                                                @if (userId == post.UserId || userId == comment.UserId)
                                                {
                                                    <form class="d-inline"
                                                          asp-controller="Comment"
                                                          asp-action="Delete"
                                                          asp-route-id="@comment.Id"
                                                          method="post">

                                                        @Html.AntiForgeryToken()

                                                        <button type="submit"
                                                                class="btn btn-link btn-sm text-danger p-0">
                                                            Delete
                                                        </button>

                                                    </form>
                                                }

                                            </div>
                                        }

                                    </div>
                                }
                            </div>

                        </div>
                    }
                </div>
            </div>

        </div>

        <!-- Private Posts -->
        <div class="col-lg-3">

            <div class="card shadow-sm border-warning">

                <div class="card-header bg-warning-subtle">
                    <h5 class="mb-0">
                        🔒 Private Posts
                    </h5>
                </div>

                <div class="card-body">

                    @if (!privatePosts.Any())
                    {
                        <div class="text-center py-4 text-muted">
                            <h6>No Private Posts</h6>
                        </div>
                    }

                    @foreach (var post in privatePosts)
                    {
                        <div class="card border-warning mb-3">

                            <div class="card-body">

                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex">
                                        <strong>@post.UserName</strong>
                                    </div>

                                    <small class="text-muted">
                                        @post.CreatedAt
                                    </small>
                                </div>

                                <p class="mb-0">
                                    @post.Description
                                </p>

                            </div>

                            <div class="card-footer bg-white">

                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-action="Details"
                                   asp-route-id="@post.Id">
                                    Details
                                </a>

                                <a class="btn btn-sm btn-outline-warning"
                                   asp-action="Edit"
                                   asp-route-id="@post.Id">
                                    Edit
                                </a>

                                <form class="d-inline"
                                      asp-action="Delete"
                                      asp-route-id="@post.Id"
                                      method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this post?');">

                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger">
                                       Delete
                                    </button>

                                </form>

                            </div>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</div>